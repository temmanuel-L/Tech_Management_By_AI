# ============================================================================
# AI 技术管理工具 (tech_mgmt_ai) 环境变量配置
# 使用方法: 复制本文件为 .env 并填入实际值
# ============================================================================

# ----- 基础配置 -----
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----- GitLab 连接器配置 -----
# GitLab 实例地址 (如: https://gitlab.com 或自建实例地址)
GITLAB_URL=http://192.168.10.81:18080
# GitLab 个人访问令牌 (需要 api 权限)
GITLAB_TOKEN=
# 要监控的 GitLab 项目ID列表 (逗号分隔, 如: 123,456,789)
GITLAB_PROJECT_IDS=107,110
# 项目 ID 到项目名称的映射 (格式: "项目ID:项目名称,项目ID:项目名称")
# 例: "123:后端服务,456:前端项目"
GITLAB_PROJECT_NAMES=
# 作者别名映射: 同一人可能用不同 git user.name 或邮箱，统一映射为规范名
# 格式: "别名1|别名2|别名3:规范名, 别名4|别名5:规范名2"
# 例: "lwh14|刘文浩|lwh:liuwenhao, uyplayer|热克甫:rekefu"
GITLAB_AUTHOR_ALIASES=


# ----- LLM 服务配置 -----
# LLM 服务商选择 (openai / deepseek / zhipu / ollama / anthropic / openai_compatible)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱 GLM
ZHIPU_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Ollama (本地模型)
OLLAMA_BASE_URL='http://192.168.10.51:11434'
OLLAMA_MODEL=alibayram/Qwen3-30B-A3B-Instruct-2507:latest

# OpenAI 兼容接口 (用于其他兼容 OpenAI API 的服务)
COMPATIBLE_API_KEY=
COMPATIBLE_BASE_URL=
COMPATIBLE_MODEL=

# ----- 飞书配置 (项目管理数据源) -----
# 飞书应用凭证 (用于获取项目管理数据)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书 Webhook 地址 (用于发送告警通知)
FEISHU_WEBHOOK_URL=

# ----- 钉钉配置 (备选通知渠道) -----
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# ============================================================================
# 数学模型系数配置
# 基于《An Elegant Puzzle》书中理念, 以下系数用于管理指标计算
# 修改前请阅读各系数的说明, 不当修改可能导致评估结果偏差
# ============================================================================

# ----- 团队状态诊断模型 (Team State Model) -----
# 参考书籍: 1.2节 "把握团队的4种状态"
# 团队状态由4个维度的加权评分决定, 权重之和应为 1.0
#
# 积压趋势权重: 衡量需求积压的增减趋势
# 积压增长 → 团队可能在 "落后" 状态
TEAM_STATE_W_BACKLOG=0.30
# 技术债占比权重: 衡量修复/偿债类任务在总任务中的比例
# 债务过高 → 团队可能在 "停滞" 状态
TEAM_STATE_W_DEBT=0.25
# 士气代理权重: 通过 Code Review 参与度间接衡量团队活跃度
# 参与度低 → 可能存在倦怠或沟通不畅
TEAM_STATE_W_MORALE=0.20
# 创新占比权重: Feature 类任务占总任务的比例
# 创新占比高 → 团队可能处于 "创新" 状态
TEAM_STATE_W_INNOVATION=0.25

# 状态判定阈值 (状态得分 S 的分界线)
# S < THRESHOLD_FALLING_BEHIND         → Falling Behind (落后)
# THRESHOLD_FALLING_BEHIND ≤ S < 0.0   → Treading Water (停滞)
# 0.0 ≤ S < THRESHOLD_INNOVATING       → Paying Down Debt (偿债)
# S ≥ THRESHOLD_INNOVATING             → Innovating (创新)
TEAM_STATE_THRESHOLD_FALLING_BEHIND=-0.3
TEAM_STATE_THRESHOLD_INNOVATING=0.3

# ----- 技术债利息率模型 (Tech Debt Interest Rate) -----
# 参考书籍: 2.5节 "用指标指导广泛的组织变革", 2.6节 "解决技术债务的唯一可扩展方法"
# 利息率 = 修复类代码变更量 / 总代码变更量
#
# 告警阈值: 当利息率超过此值时触发告警
# 含义: 团队超过 30% 的精力在 "还利息", 应考虑启动集中偿债
TECH_DEBT_ALERT_THRESHOLD=0.30
# 危险阈值: 超过此值表明债务已严重影响生产力
TECH_DEBT_DANGER_THRESHOLD=0.50
# 识别修复类 Commit 的关键词 (英文逗号分隔)
TECH_DEBT_FIX_KEYWORDS=fix,bugfix,hotfix,patch,repair,resolve

# ----- DORA 指标模型 (DORA Metrics) -----
# 参考书籍: 2.1节 "系统思维" 中的四个开发人员速度关键指标
# 参考文献: Nicole Forsgren 等《Accelerate》
#
# Lead Time (变更前置时间) 分级阈值 (单位: 小时)
# Elite: < 24h, High: < 168h(7天), Medium: < 720h(30天), Low: ≥ 720h
DORA_LEAD_TIME_ELITE_HOURS=24
DORA_LEAD_TIME_HIGH_HOURS=168
DORA_LEAD_TIME_MEDIUM_HOURS=720
#
# Deployment Frequency (部署频率) 分级阈值 (单位: 次/天)
# Elite: ≥ 1次/天, High: ≥ 1次/周, Medium: ≥ 1次/月, Low: < 1次/月
DORA_DEPLOY_FREQ_ELITE_PER_DAY=1.0
DORA_DEPLOY_FREQ_HIGH_PER_DAY=0.143
DORA_DEPLOY_FREQ_MEDIUM_PER_DAY=0.033
#
# Change Failure Rate (变更失败率) 分级阈值 (0.0-1.0)
# Elite: < 5%, High: < 10%, Medium: < 15%, Low: ≥ 15%
DORA_CFR_ELITE=0.05
DORA_CFR_HIGH=0.10
DORA_CFR_MEDIUM=0.15
#
# MTTR (平均恢复时间) 分级阈值 (单位: 小时)
# Elite: < 1h, High: < 24h, Medium: < 168h(7天), Low: ≥ 168h
DORA_MTTR_ELITE_HOURS=1
DORA_MTTR_HIGH_HOURS=24
DORA_MTTR_MEDIUM_HOURS=168

# ----- 英雄检测模型 (Hero Detector) -----
# 参考书籍: 4.6节 "消灭英雄, 努力工作并不能保证成功"
# 使用基尼系数衡量代码提交集中度
#
# 重度英雄依赖阈值: 基尼系数超过此值触发告警
# 含义: 代码提交高度集中于少数人, 存在单点风险
HERO_GINI_ALERT_THRESHOLD=0.6
# 中度集中提醒阈值
HERO_GINI_WARNING_THRESHOLD=0.4

# ----- 团队规模校准模型 (Team Sizing) -----
# 参考书籍: 1.1节 "4个原则确定团队规模"
#
# 经理:工程师 最佳比例范围
TEAM_SIZING_MGR_ENG_MIN=6
TEAM_SIZING_MGR_ENG_MAX=8
# 高级经理:经理 最佳比例范围
TEAM_SIZING_DIR_MGR_MIN=4
TEAM_SIZING_DIR_MGR_MAX=6
# 团队最小人数 (低于此数难以形成团队文化)
TEAM_SIZING_MIN_TEAM_SIZE=4
# 值班轮值最少人数
TEAM_SIZING_MIN_ONCALL_SIZE=8

# ----- 综合健康分模型 (Health Score) -----
# 将所有模型输出加权聚合为 0-100 的综合分
# 权重之和应为 1.0
#
# DORA 指标权重
HEALTH_W_DORA=0.30
# 技术债权重 (取反: 债务越低, 健康分越高)
HEALTH_W_DEBT=0.25
# 英雄检测权重 (取反: 基尼系数越低, 健康分越高)
HEALTH_W_HERO=0.20
# 团队状态权重
HEALTH_W_STATE=0.25
